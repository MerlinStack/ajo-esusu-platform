rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    /* ───── Users ───── */
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    /* ───── Circles ───── */
    match /circles/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ───── Circle Members ───── */
    match /circleMembers/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(get(/databases/$(database)/documents/circleMembers/$(id)).data.userId);
    }

    /* ───── Transactions ───── */
    match /transactions/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /* ───── Notifications ───── */
    match /notifications/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isOwner(get(/databases/$(database)/documents/notifications/$(id)).data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /* ───── Audit Logs ───── */
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
